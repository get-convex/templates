{
  "name": "template-react-vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "convex dev --start 'vite --open'",
    "predev": "convex init && node setup.mjs --once",
    "build": "tsc -b && vite build",
